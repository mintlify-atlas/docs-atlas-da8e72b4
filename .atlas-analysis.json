  "keyFeatures": [
    "Real-time cricket match scoring with WebSocket support",
    "Tournament management with groups and points tables",
    "Comprehensive player and team statistics tracking",
    "Multi-format cricket support (T20, ODI, Test)",
    "Redis caching for performance optimization",
    "Role-based access control and JWT authentication",
    "Firebase integration for notifications",
    "Stripe payment integration",
    "Offline sync capabilities",
    "Cluster mode support with PM2"
  ],
  "publicApiSurface": [
    "POST /v1/auth/register - User registration",
    "POST /v1/auth/login - User authentication",
    "POST /v1/matches - Create new match",
    "GET /v1/matches/:id - Get match details",
    "POST /v1/tournaments - Create tournament",
    "GET /v1/tournaments/:id - Get tournament details",
    "POST /v1/teams - Create team",
    "GET /v1/teams/:id - Get team details",
    "POST /v1/players - Create player",
    "GET /v1/players/:id - Get player details",
    "POST /v1/innings - Create innings",
    "POST /v1/overs - Create over",
    "POST /v1/balls - Record ball",
    "GET /v1/stats/player/:id - Get player statistics",
    "GET /v1/stats/team/:id - Get team statistics",
    "GET /v1/notifications - Get notifications",
    "POST /v1/admin/users - Admin user management",
    "DELETE /v1/cache - Clear cache"
  ]
}
